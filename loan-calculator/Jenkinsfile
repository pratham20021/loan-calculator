pipeline {
    agent any

    tools {
        maven 'Default Maven'
        jdk   'JDK17'
    }

    environment {
        DOCKER_IMAGE = "Pratahamesh2019/loan-calculator:latest" // ← Replace with your Docker Hub username
        TF_DIR       = "terraform"
        PEM_FILE     = "terraform\\loan-calculator-key.pem"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                bat 'mvn clean package -DskipTests -q'
            }
        }

        stage('Docker Build & Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    bat "docker build -t %DOCKER_USER%/loan-calculator:latest ."
                    bat "docker login -u %DOCKER_USER% -p %DOCKER_PASS%"
                    bat "docker push %DOCKER_USER%/loan-calculator:latest"
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                withCredentials([
                    string(credentialsId: 'aws-access-key-id',     variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'aws-secret-access-key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    dir("${TF_DIR}") {
                        bat 'terraform init'
                        bat 'terraform apply -auto-approve'
                        script {
                            // bat on Windows prints an extra line with the command itself
                            // so we strip it by taking only the last non-empty line
                            def rawOutput = bat(script: 'terraform output -raw ec2_public_ip', returnStdout: true).trim()
                            env.EC2_IP = rawOutput.tokenize('\n').last().trim()
                        }
                    }
                }
            }
        }

        stage('Wait for EC2') {
            steps {
                // Give EC2 ~60 seconds to finish user_data (Docker install + container start)
                bat 'ping -n 61 127.0.0.1 > nul'
            }
        }

        stage('Deploy to EC2') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    // Windows OpenSSH: pass commands to EC2 via ssh using the .pem Terraform saved
                    bat """
                        ssh -o StrictHostKeyChecking=no -i %PEM_FILE% ec2-user@%EC2_IP% ^
                        "docker pull %DOCKER_USER%/loan-calculator:latest && ^
                         docker stop loan-calculator ; ^
                         docker rm loan-calculator ; ^
                         docker run -d --name loan-calculator --restart always -p 8080:8080 %DOCKER_USER%/loan-calculator:latest"
                    """
                    echo "App deployed at: http://%EC2_IP%:8080"
                }
            }
        }
    }

    post {
        success { echo "Pipeline succeeded. App running at http://${env.EC2_IP}:8080" }
        failure { echo "Pipeline failed. Check logs above." }
    }
}
